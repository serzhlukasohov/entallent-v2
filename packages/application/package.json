{
  "name": "@entalent/application",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@entalent/eslint-config": "workspace:*",
    "@entalent/typescript-config": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@entalent/contracts": "workspace:*"
  }
}
