{
  "name": "@entalent/database",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@entalent/eslint-config": "workspace:*",
    "@entalent/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.26.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@entalent/config": "workspace:*",
    "drizzle-orm": "^0.35.0",
    "postgres": "^3.4.4"
  }
}
